<body>

<div class="box">

<h1>☀️ SOLAR TOOL</h1>

<label>Roof / Area (m²)</label>
<input id="area" type="number" placeholder="ဥပမာ 100">

<label>Solar Panel Watt</label>
<select id="panel">
<option value="615">615W</option>
<option value="650">650W</option>
<option value="700">700W</option>
<option value="720">720W</option>
<option value="750">750W</option>
</select>


<label>Panel Length (m)</label>
<input id="length" type="number" value="2.38">

<label>Panel Width (m)</label>
<input id="width" type="number" value="1.30">


<label>Available Area %</label>
<input id="use" type="number" value="80">


<button onclick="calculate()">CALCULATE</button>


<div class="result" id="result">
Result Here...
</div>

</div>


<script>

function calculate(){

let area =
Number(document.getElementById("area").value);

let watt =
Number(document.getElementById("panel").value);

let length =
Number(document.getElementById("length").value);

let width =
Number(document.getElementById("width").value);

let use =
Number(document.getElementById("use").value);


let panelArea = length * width;

let usableArea = area * use /100;

let qty = Math.floor(usableArea / panelArea);

let totalWatt = qty * watt;

let kw = totalWatt /1000;


document.getElementById("result").innerHTML =

"Panel Qty : "+qty+" pcs<br>"+
"Panel Watt : "+watt+" W<br>"+
"Solar Size : "+kw.toFixed(2)+" kW<br>"+
"Area Used : "+(qty*panelArea).toFixed(2)+" m²";


}

</script>

</body>
</html>

