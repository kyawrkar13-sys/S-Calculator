<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>SOLAR TOOL</title>

<style>
body{
    font-family:Arial;
    background:#f2f5f7;
    padding:20px;
}
.box{
    background:white;
    padding:20px;
    border-radius:12px;
    max-width:700px;
    margin:auto;
    box-shadow:0 0 10px #aaa;
}
h1{
    text-align:center;
    color:#ff9800;
}
input,select,button{
    width:100%;
    padding:10px;
    margin:6px 0;
    border-radius:6px;
    border:1px solid #aaa;
}
button{
    background:#ff9800;
    color:white;
