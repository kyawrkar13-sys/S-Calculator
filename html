: <h2>🔋 Battery kWh Auto (Universal Voltage)</h2>

<label>Load (Watt)</label>
<input id="batLoad" type="number" placeholder="ဥပမာ 5000">

<label>Backup Time (Hour)</label>
<input id="backupHour" type="number" value="8">

<label>Battery Voltage (V)</label>
<input id="batteryVoltage" type="number" value="51.2" placeholder="48 / 51.2 / 96 / 384">

<label>Battery Efficiency (%)</label>
<input id="efficiency" type="number" value="90">


<button onclick="batteryAuto()">CALCULATE</button>

<div id="batteryResult" class="result"></div>


<script>

function batteryAuto(){

let load = Number(document.getElementById("batLoad").value);
let hour = Number(document.getElementById("backupHour").value);
let voltage = Number(document.getElementById("batteryVoltage").value);
let eff = Number(document.getElementById("efficiency").value);


// Energy kWh
let energy = (load * hour) / 1000;


// Efficiency compensate
let batteryKwh = energy / (eff/100);


// Ah calculation
let batteryAh = (batteryKwh * 1000) / voltage;


document.getElementById("batteryResult").innerHTML =

"Battery Energy : "+
batteryKwh.toFixed(2)+" kWh<br><br>"+

"Battery Voltage : "+
voltage+" V<br><br>"+

"Required Battery : "+
batteryAh.toFixed(1)+" Ah";

}

</script>
